# ── LLM Provider ─────────────────────────────────────────────────────────
# Which AI API to use. Any provider LangChain's init_chat_model() supports:
# anthropic | openai | google_genai | groq | mistralai | xai | ollama |
# fireworks | together | cohere | bedrock | google_vertexai
LLM_PROVIDER=google_genai

# Model name/id for the chosen provider. A few examples:
#   anthropic:    claude-sonnet-4-6
#   openai:       gpt-5
#   google_genai: gemini-2.5-flash   (or gemini-3.5-flash for stronger coding)
#   groq:         llama-3.3-70b-versatile
#   mistralai:    mistral-large-latest
#   xai:          grok-4
#   ollama:       llama3.1              (runs locally, no API key needed)
AGENT_MODEL=gemini-2.5-flash

# ── API Key ──────────────────────────────────────────────────────────────
# Set the ONE that matches your LLM_PROVIDER above (or set LLM_API_KEY,
# which always wins and works no matter which provider you pick).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
GEMINI_API_KEY=your-key-here
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
# FIREWORKS_API_KEY=
# TOGETHER_API_KEY=
# COHERE_API_KEY=
# LLM_API_KEY=          # universal override — works for any provider above

# ── Workflow tuning ──────────────────────────────────────────────────────
# Max Coder -> Reviewer -> Executor -> Tester loops before giving up
MAX_ITERATIONS=4

# Seconds before the sandboxed execution/tests are killed
EXECUTION_TIMEOUT=10

# "subprocess" (default, no extra setup) or "docker" (real isolation,
# requires Docker installed and running locally)
SANDBOX_BACKEND=subprocess
